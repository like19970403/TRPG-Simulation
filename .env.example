# Server
PORT=8080
LOG_LEVEL=info

# Database — Docker Compose host port for PostgreSQL
# Makefile 會自動用此值組合 DATABASE_URL，只需改這裡
# PG_HOST_PORT=5432

# Docker Compose host port for app
# APP_HOST_PORT=0.0.0.0:3000

# JWT — secret MUST be >= 32 characters. Generate one with:
#   openssl rand -base64 48
#   or: make generate-secret
JWT_SECRET=change-me-to-a-secure-random-string-at-least-32-chars
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800
BCRYPT_COST=12
COOKIE_SECURE=true  # Set to false for local HTTP development

# Maximum JSON request body size in bytes (default: 1MB = 1048576)
# MAX_JSON_BODY_SIZE=1048576

# WebSocket allowed origins (comma-separated, empty = same-host only)
# ALLOWED_ORIGINS=https://trpg.example.com
